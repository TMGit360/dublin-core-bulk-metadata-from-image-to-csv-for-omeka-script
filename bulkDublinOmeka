#!/usr/bin/env python3
"""
Generate a BatchUpload-compatible CSV for Omeka Classic from image files.

Workflow:
  1. Run this script from (or point it at) the folder containing your images.
  2. Choose an output filename and select which Dublin Core fields to bulk-set.
  3. Open the resulting CSV and fill in per-image values before uploading.
  4. In Omeka BatchUpload, upload the CSV and image files together.

Column mapping:
  - 'file'              → File (sidecar filename matched against uploaded file)
  - 'Dublin Core:Title' → DC Title element (explicit prefix avoids Omeka's
                          internal item-title field conflict)
  - All other headers are Dublin Core element names and auto-map by exact name.

Requires: exiftool  (sudo apt install libimage-exiftool-perl)
"""

import argparse
import csv
import itertools
import json
import os
import re
import subprocess
import sys
import threading
import time
from pathlib import Path

import requests

# Output CSV column order. 'file' MUST be first; remaining columns follow the
# Dublin Core Metadata Element Set standard order.
COLUMNS = [
    "file",
    "Dublin Core:Title",
    "Creator",
    "Subject",
    "Description",
    "Publisher",
    "Contributor",
    "Date",
    "Type",
    "Format",
    "Identifier",
    "Source",
    "Language",
    "Relation",
    "Coverage",
    "Rights",
]

# All 15 Dublin Core elements in standard DCMES order.
# (internal_key, display_label, input_hint, auto_note)
#   internal_key  — key used in the shared dict and build_row
#   display_label — shown in the selection menu
#   input_hint    — shown at value-entry time (e.g. "comma-separated")
#   auto_note     — describes what EXIF provides automatically if not bulk-set
DC_FIELDS = [
    ("Title",       "Title",       "",                "auto: filename stem"),
    ("Creator",     "Creator",     "",                ""),
    ("Subject",     "Subject",     "comma-separated", ""),
    ("Description", "Description", "",                ""),
    ("Publisher",   "Publisher",   "",                ""),
    ("Contributor", "Contributor", "",                ""),
    ("Date",        "Date",        "",                "auto: EXIF date"),
    ("Type",        "Type",        "",                ""),
    ("Format",      "Format",      "",                "auto: MIME type"),
    ("Identifier",  "Identifier",  "",                "auto: filename"),
    ("Source",      "Source",      "",                ""),
    ("Language",    "Language",    "",                ""),
    ("Relation",    "Relation",    "",                ""),
    ("Coverage",    "Coverage",    "",                "auto: GPS location"),
    ("Rights",      "Rights",      "",                ""),
]

# Supported extensions and their MIME types.
IMAGE_TYPES: dict[str, str] = {
    ".jpg":  "image/jpeg",
    ".jpeg": "image/jpeg",
    ".heic": "image/heic",
    ".heif": "image/heif",
    ".tif":  "image/tiff",
    ".tiff": "image/tiff",
    ".png":  "image/png",
    ".gif":  "image/gif",
    ".bmp":  "image/bmp",
    ".webp": "image/webp",
    ".dng":  "image/x-adobe-dng",
    ".cr2":  "image/x-canon-cr2",
    ".nef":  "image/x-nikon-nef",
    ".arw":  "image/x-sony-arw",
}


# ── Spinner ────────────────────────────────────────────────────────────────────

class Spinner:
    """Context manager that shows an animated spinner while work is running."""

    _FRAMES = ('|', '/', '-', '\\')

    def __init__(self, message: str):
        self.message = message
        self._stop   = threading.Event()
        self._thread = threading.Thread(target=self._spin, daemon=True)

    def _spin(self) -> None:
        for frame in itertools.cycle(self._FRAMES):
            if self._stop.is_set():
                break
            sys.stdout.write(f"\r  {frame}  {self.message}")
            sys.stdout.flush()
            time.sleep(0.1)

    def __enter__(self):
        self._thread.start()
        return self

    def __exit__(self, *_) -> None:
        self._stop.set()
        self._thread.join()
        sys.stdout.write(f"\r{' ' * (len(self.message) + 6)}\r")
        sys.stdout.flush()


# ── Image utilities ────────────────────────────────────────────────────────────

def collect_images(directory: Path) -> list[Path]:
    seen, paths = set(), []
    for p in sorted(directory.iterdir()):
        if p.suffix.lower() in IMAGE_TYPES and p.name not in seen:
            seen.add(p.name)
            paths.append(p)
    return paths


def mime_type(path: Path) -> str:
    return IMAGE_TYPES.get(path.suffix.lower(), "image/jpeg")


def run_exiftool(paths: list[Path]) -> list[dict]:
    """Return exiftool JSON records for all paths. -n gives decimal GPS."""
    cmd = ["exiftool", "-j", "-n", "--"] + [str(p) for p in paths]
    result = subprocess.run(cmd, capture_output=True, text=True, check=True)
    return json.loads(result.stdout)


def format_date(raw) -> str:
    """Convert raw date to Dublin Core format.

    Year span (e.g. '2001-2003' or '2001/2003') → '2001/2003'
    Single EXIF date (e.g. '2024:01:27 11:48:06') → '2024-01-27'
    """
    if not raw:
        return ""
    s = str(raw).strip()

    m = re.match(r'^(\d{4})\s*[-/]\s*(\d{4})$', s)
    if m:
        return f"{m.group(1)}/{m.group(2)}"

    date_part = s.split(" ")[0]
    date_part = re.sub(r'[+-]\d{2}:\d{2}$', '', date_part)
    return date_part.replace(":", "-")


_geocode_cache: dict[tuple[float, float], str] = {}

def reverse_geocode(exif: dict) -> str:
    """Return a human-readable location from GPS coords, or '' if absent.

    Uses Nominatim (OpenStreetMap) — no API key required.
    Results are cached by rounded coordinates to avoid redundant requests.
    US: "City, State". International: "City, State, Country" or "City, Country".
    Falls back to raw decimal coords if the API call fails.
    """
    lat = exif.get("GPSLatitude")
    lon = exif.get("GPSLongitude")
    if lat is None or lon is None:
        return ""

    lat, lon = float(lat), float(lon)
    cache_key = (round(lat, 3), round(lon, 3))
    if cache_key in _geocode_cache:
        return _geocode_cache[cache_key]

    try:
        time.sleep(1)  # Nominatim rate limit: 1 req/sec
        resp = requests.get(
            "https://nominatim.openstreetmap.org/reverse",
            params={"lat": lat, "lon": lon, "format": "json"},
            headers={"User-Agent": "OmekaMetadataScript/1.0"},
            timeout=10,
        )
        resp.raise_for_status()
        addr = resp.json().get("address", {})

        city = (
            addr.get("city")
            or addr.get("town")
            or addr.get("village")
            or addr.get("hamlet")
            or addr.get("county")
            or ""
        )
        state        = addr.get("state", "")
        country      = addr.get("country", "")
        country_code = addr.get("country_code", "").upper()

        if country_code == "US":
            parts = [p for p in [city, state] if p]
        else:
            parts = [p for p in [city, state, country] if p]

        result = ", ".join(parts) if parts else f"{lat:.6f}, {lon:.6f}"
    except Exception:
        result = f"{lat:.6f}, {lon:.6f}"

    _geocode_cache[cache_key] = result
    return result


# ── Prompts ────────────────────────────────────────────────────────────────────

def prompt_output_name() -> str:
    """Ask the user for the output CSV filename (extension is added automatically)."""
    print()
    raw = input("  Output file name (just the name, no extension): ").strip()
    if not raw:
        raw = "batch_upload"
    # Be forgiving if they typed the extension anyway
    if raw.lower().endswith(".csv"):
        raw = raw[:-4]
    return raw


def _parse_selection(raw: str) -> list[int]:
    """Parse a space/comma-separated string of field numbers into an ordered list."""
    seen, result = set(), []
    for token in re.split(r"[\s,]+", raw):
        if token.isdigit():
            idx = int(token)
            if 1 <= idx <= len(DC_FIELDS) and idx not in seen:
                result.append(idx)
                seen.add(idx)
    return result


def prompt_shared_fields() -> dict:
    """Interactive loop for selecting and entering shared Dublin Core values.

    The menu redisplays after each round so the user can review what is set
    and choose additional fields — or press Enter to finish.

    - Fields already set show their current value in the menu.
    - Re-selecting a field and leaving the value blank clears it.
    - Subject values are entered comma-separated and stored with Omeka's ^^
      multi-value separator so each term maps as a distinct Subject element.
    """
    SEP     = "-" * 66
    label_w = max(len(label) for _, label, _, _ in DC_FIELDS)
    shared: dict[str, str] = {}

    while True:
        # ── Print menu ─────────────────────────────────────────────────────────
        print()
        print(SEP)
        print("  DUBLIN CORE FIELDS")
        print("  Select fields to set to the same value across all images.")
        print("  Fields marked 'auto' are filled from EXIF if left unset.")
        print(SEP)
        print()

        for i, (key, label, _, auto_note) in enumerate(DC_FIELDS, start=1):
            if key in shared:
                # Show the current value; Subject stored as ^^ but display with commas
                display = shared[key].replace("^^", ", ")
                annotation = f"  =  {display}"
            elif auto_note:
                annotation = f"  ({auto_note})"
            else:
                annotation = ""
            print(f"  {i:>2}.  {label:<{label_w}}{annotation}")

        print()

        if shared:
            prompt_txt = "  Enter field numbers to add or change, or press Enter to continue: "
        else:
            prompt_txt = "  Enter field numbers to bulk-set (e.g. 1 3 8), or press Enter to skip all: "

        raw = input(prompt_txt).strip()
        print()

        selected = _parse_selection(raw)
        if not selected:
            break  # user is done

        # ── Enter values for chosen fields ─────────────────────────────────────
        print(SEP)
        if any(k in shared for k, *_ in [DC_FIELDS[i - 1] for i in selected]):
            print("  ENTER VALUES  (leave blank to clear an existing value)")
        else:
            print("  ENTER VALUES  (leave blank to omit a field)")
        print(SEP)
        print()

        for idx in selected:
            key, label, hint, _ = DC_FIELDS[idx - 1]
            suffix  = f" ({hint})" if hint else ""
            current = f"  [current: {shared[key].replace('^^', ', ')}]" if key in shared else ""
            value   = input(f"  {label}{suffix}{current}: ").strip()

            if value:
                if key == "Subject":
                    terms = [t.strip() for t in value.split(",") if t.strip()]
                    value = "^^".join(terms)
                shared[key] = value
            elif key in shared:
                del shared[key]  # blank input clears a previously set value

        print()
        # Loop: redisplay updated menu so user can review and add more

    return shared


# ── Row builder ────────────────────────────────────────────────────────────────

def build_row(exif: dict, shared: dict) -> dict:
    """Build one CSV row. Shared values take precedence; EXIF fills the rest."""
    filename = os.path.basename(exif.get("SourceFile", ""))

    def field(key, exif_val=""):
        return shared[key] if key in shared else exif_val

    return {
        "file":              filename,
        "Dublin Core:Title": field("Title",      Path(filename).stem),
        "Creator":           field("Creator"),
        "Subject":           field("Subject"),
        "Description":       field("Description"),
        "Publisher":         field("Publisher"),
        "Contributor":       field("Contributor"),
        "Date":              field("Date",        format_date(exif.get("DateTimeOriginal") or exif.get("CreateDate"))),
        "Type":              field("Type"),
        "Format":            field("Format",      mime_type(Path(filename))),
        "Identifier":        field("Identifier",  filename),
        "Source":            field("Source"),
        "Language":          field("Language"),
        "Relation":          field("Relation"),
        "Coverage":          field("Coverage",    reverse_geocode(exif)),
        "Rights":            field("Rights"),
    }


# ── Main ───────────────────────────────────────────────────────────────────────

def main() -> None:
    parser = argparse.ArgumentParser(
        description="Generate a BatchUpload-compatible CSV for Omeka Classic."
    )
    parser.add_argument(
        "directory",
        nargs="?",
        default=".",
        help="Folder containing image files (default: current directory)",
    )
    args = parser.parse_args()

    directory = Path(args.directory).resolve()
    if not directory.is_dir():
        sys.exit(f"Error: '{directory}' is not a directory.")

    images = collect_images(directory)
    if not images:
        supported = ", ".join(sorted(IMAGE_TYPES))
        sys.exit(f"No supported image files found in '{directory}'.\nSupported: {supported}")

    print(f"\n  Found {len(images)} image(s) in {directory}")

    # ── User prompts (all input gathered before processing begins) ─────────────
    output_name = prompt_output_name()
    shared      = prompt_shared_fields()

    # ── Read EXIF metadata ─────────────────────────────────────────────────────
    try:
        with Spinner("Reading image metadata..."):
            exif_records = run_exiftool(images)
    except FileNotFoundError:
        sys.exit("Error: exiftool not found. Install with: sudo apt install libimage-exiftool-perl")
    except subprocess.CalledProcessError as e:
        sys.exit(f"exiftool failed: {e.stderr}")

    exif_by_name = {
        os.path.basename(r.get("SourceFile", "")): r for r in exif_records
    }

    # ── Build and write CSV ────────────────────────────────────────────────────
    output_path  = directory / f"{output_name}.csv"
    total        = len(images)
    rows_written = 0
    last_width   = 0

    with open(output_path, "w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=COLUMNS)
        writer.writeheader()

        for i, img_path in enumerate(images, start=1):
            status = f"  [{i}/{total}]  {img_path.name}"
            sys.stdout.write(f"\r{status}")
            sys.stdout.flush()
            last_width = len(status)

            exif = exif_by_name.get(img_path.name, {"SourceFile": str(img_path)})
            writer.writerow(build_row(exif, shared))
            rows_written += 1

    # Clear the progress line before printing the final summary
    sys.stdout.write(f"\r{' ' * last_width}\r")
    sys.stdout.flush()

    print(f"  Done — wrote {rows_written} rows to {output_path}")
    print()
    print("  Next steps:")
    print("  1. Open the CSV and fill in any per-image fields as needed.")
    print("  2. In Omeka: BatchUpload → New Job → Existing Collection")
    print("  3. Upload the CSV; map 'file' → File and confirm the Dublin Core columns.")
    print("  4. Upload the image files when prompted in step 4.")
    print()


if __name__ == "__main__":
    main()
